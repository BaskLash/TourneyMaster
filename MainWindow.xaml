<Window x:Class="Turnierspielplan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Turnierspielplan"
        mc:Ignorable="d"
        Title="Turnierspielplan" Height="882" Width="1300"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">
    <Window.Resources>
        <!-- Template shared by every slot's ComboBox -->
        <DataTemplate x:Key="TeamItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0"
                       Source="{Binding ImagePath}"
                       Width="28" Height="28"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           FontSize="17"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,6,0"/>
            </Grid>
        </DataTemplate>

        <!-- Container style: unavailable items are disabled but visible -->
        <Style x:Key="TeamSlotItemContainerStyle" TargetType="ComboBoxItem"
               BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="IsEnabled" Value="{Binding IsAvailable}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.30*"/>
            <ColumnDefinition Width="0.08*"/>
            <ColumnDefinition Width="0.21*"/>
            <ColumnDefinition Width="0.21*"/>
            <ColumnDefinition Width="0.20*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- ==================== Title ==================== -->
        <Label Content="Turnierspielplan"
               Grid.Column="2" Grid.ColumnSpan="3"
               Style="{StaticResource TitleLabel}"
               HorizontalAlignment="Left"
               VerticalAlignment="Center"
               Margin="12,0,0,0"/>

        <!-- ==================== Slot 1 ==================== -->
        <Rectangle Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource SlotCard}"/>
        <ComboBox x:Name="Mannschaft1" Grid.Row="1" Grid.Column="0" Margin="8"
                  ItemTemplate="{StaticResource TeamItemTemplate}"
                  ItemContainerStyle="{StaticResource TeamSlotItemContainerStyle}"
                  SelectedValuePath="Team.Name"
                  SelectionChanged="Slot_SelectionChanged"/>
        <Label Content="-" Name="lblTore1" Style="{StaticResource ScoreLabel}"
               Grid.Row="1" Grid.Column="1"/>

        <!-- ==================== Slot 2 ==================== -->
        <Rectangle Grid.Row="3" Grid.ColumnSpan="2" Style="{StaticResource SlotCard}"/>
        <ComboBox x:Name="Mannschaft2" Grid.Row="3" Grid.Column="0" Margin="8"
                  ItemTemplate="{StaticResource TeamItemTemplate}"
                  ItemContainerStyle="{StaticResource TeamSlotItemContainerStyle}"
                  SelectedValuePath="Team.Name"
                  SelectionChanged="Slot_SelectionChanged"/>
        <Label Content="-" Name="lblTore2" Style="{StaticResource ScoreLabel}"
               Grid.Row="3" Grid.Column="1"/>

        <!-- ==================== Slot 3 ==================== -->
        <Rectangle Grid.Row="5" Grid.ColumnSpan="2" Style="{StaticResource SlotCard}"/>
        <ComboBox x:Name="Mannschaft3" Grid.Row="5" Grid.Column="0" Margin="8"
                  ItemTemplate="{StaticResource TeamItemTemplate}"
                  ItemContainerStyle="{StaticResource TeamSlotItemContainerStyle}"
                  SelectedValuePath="Team.Name"
                  SelectionChanged="Slot_SelectionChanged"/>
        <Label Content="-" Name="lblTore3" Style="{StaticResource ScoreLabel}"
               Grid.Row="5" Grid.Column="1"/>

        <!-- ==================== Slot 4 ==================== -->
        <Rectangle Grid.Row="7" Grid.ColumnSpan="2" Style="{StaticResource SlotCard}"/>
        <ComboBox x:Name="Mannschaft4" Grid.Row="7" Grid.Column="0" Margin="8"
                  ItemTemplate="{StaticResource TeamItemTemplate}"
                  ItemContainerStyle="{StaticResource TeamSlotItemContainerStyle}"
                  SelectedValuePath="Team.Name"
                  SelectionChanged="Slot_SelectionChanged"/>
        <Label Content="-" Name="lblTore4" Style="{StaticResource ScoreLabel}"
               Grid.Row="7" Grid.Column="1"/>

        <!-- ==================== Slot 5 ==================== -->
        <Rectangle Grid.Row="9" Grid.ColumnSpan="2" Style="{StaticResource SlotCard}"/>
        <ComboBox x:Name="Mannschaft5" Grid.Row="9" Grid.Column="0" Margin="8"
                  ItemTemplate="{StaticResource TeamItemTemplate}"
                  ItemContainerStyle="{StaticResource TeamSlotItemContainerStyle}"
                  SelectedValuePath="Team.Name"
                  SelectionChanged="Slot_SelectionChanged"/>
        <Label Content="-" Name="lblTore5" Style="{StaticResource ScoreLabel}"
               Grid.Row="9" Grid.Column="1"/>

        <!-- ==================== Slot 6 ==================== -->
        <Rectangle Grid.Row="11" Grid.ColumnSpan="2" Style="{StaticResource SlotCard}"/>
        <ComboBox x:Name="Mannschaft6" Grid.Row="11" Grid.Column="0" Margin="8"
                  ItemTemplate="{StaticResource TeamItemTemplate}"
                  ItemContainerStyle="{StaticResource TeamSlotItemContainerStyle}"
                  SelectedValuePath="Team.Name"
                  SelectionChanged="Slot_SelectionChanged"/>
        <Label Content="-" Name="lblTore6" Style="{StaticResource ScoreLabel}"
               Grid.Row="11" Grid.Column="1"/>

        <!-- ==================== Slot 7 ==================== -->
        <Rectangle Grid.Row="13" Grid.ColumnSpan="2" Style="{StaticResource SlotCard}"/>
        <ComboBox x:Name="Mannschaft7" Grid.Row="13" Grid.Column="0" Margin="8"
                  ItemTemplate="{StaticResource TeamItemTemplate}"
                  ItemContainerStyle="{StaticResource TeamSlotItemContainerStyle}"
                  SelectedValuePath="Team.Name"
                  SelectionChanged="Slot_SelectionChanged"/>
        <Label Content="-" Name="lblTore7" Style="{StaticResource ScoreLabel}"
               Grid.Row="13" Grid.Column="1"/>

        <!-- ==================== Slot 8 ==================== -->
        <Rectangle Grid.Row="15" Grid.ColumnSpan="2" Style="{StaticResource SlotCard}"/>
        <ComboBox x:Name="Mannschaft8" Grid.Row="15" Grid.Column="0" Margin="8"
                  ItemTemplate="{StaticResource TeamItemTemplate}"
                  ItemContainerStyle="{StaticResource TeamSlotItemContainerStyle}"
                  SelectedValuePath="Team.Name"
                  SelectionChanged="Slot_SelectionChanged"/>
        <Label Content="-" Name="lblTore8" Style="{StaticResource ScoreLabel}"
               Grid.Row="15" Grid.Column="1"/>

        <!-- ==================== Round 1 winners ==================== -->
        <Rectangle Grid.Row="2" Grid.Column="2" Style="{StaticResource BracketCard}"/>
        <Label Content="Gewinner Spiel 1" Grid.Row="2" Grid.Column="2"
               Style="{StaticResource HeadingLabel}"
               HorizontalAlignment="Left" Margin="14,0,0,0"/>
        <Label Content="-" Name="lblErsteGewinner1" Grid.Row="2" Grid.Column="2"
               Style="{StaticResource WinnerNameLabel}"
               HorizontalAlignment="Right" Margin="0,0,56,0"/>
        <Label Content="-" Name="lblErsteGewinner1Tore" Grid.Row="2" Grid.Column="2"
               Style="{StaticResource ScoreLabel}"
               HorizontalAlignment="Right" Margin="0,0,14,0" Width="36"/>

        <Rectangle Grid.Row="6" Grid.Column="2" Style="{StaticResource BracketCard}"/>
        <Label Content="Gewinner Spiel 2" Grid.Row="6" Grid.Column="2"
               Style="{StaticResource HeadingLabel}"
               HorizontalAlignment="Left" Margin="14,0,0,0"/>
        <Label Content="-" Name="lblErsteGewinner2" Grid.Row="6" Grid.Column="2"
               Style="{StaticResource WinnerNameLabel}"
               HorizontalAlignment="Right" Margin="0,0,56,0"/>
        <Label Content="-" Name="lblErsteGewinner2Tore" Grid.Row="6" Grid.Column="2"
               Style="{StaticResource ScoreLabel}"
               HorizontalAlignment="Right" Margin="0,0,14,0" Width="36"/>

        <Rectangle Grid.Row="10" Grid.Column="2" Style="{StaticResource BracketCard}"/>
        <Label Content="Gewinner Spiel 3" Grid.Row="10" Grid.Column="2"
               Style="{StaticResource HeadingLabel}"
               HorizontalAlignment="Left" Margin="14,0,0,0"/>
        <Label Content="-" Name="lblErsteGewinner3" Grid.Row="10" Grid.Column="2"
               Style="{StaticResource WinnerNameLabel}"
               HorizontalAlignment="Right" Margin="0,0,56,0"/>
        <Label Content="-" Name="lblErsteGewinner3Tore" Grid.Row="10" Grid.Column="2"
               Style="{StaticResource ScoreLabel}"
               HorizontalAlignment="Right" Margin="0,0,14,0" Width="36"/>

        <Rectangle Grid.Row="14" Grid.Column="2" Style="{StaticResource BracketCard}"/>
        <Label Content="Gewinner Spiel 4" Grid.Row="14" Grid.Column="2"
               Style="{StaticResource HeadingLabel}"
               HorizontalAlignment="Left" Margin="14,0,0,0"/>
        <Label Content="-" Name="lblErsteGewinner4" Grid.Row="14" Grid.Column="2"
               Style="{StaticResource WinnerNameLabel}"
               HorizontalAlignment="Right" Margin="0,0,56,0"/>
        <Label Content="-" Name="lblErsteGewinner4Tore" Grid.Row="14" Grid.Column="2"
               Style="{StaticResource ScoreLabel}"
               HorizontalAlignment="Right" Margin="0,0,14,0" Width="36"/>

        <!-- ==================== Semifinals ==================== -->
        <Rectangle Grid.Row="4" Grid.Column="3" Style="{StaticResource BracketCard}"/>
        <Label Content="Gewinner HF 1" Grid.Row="4" Grid.Column="3"
               Style="{StaticResource HeadingLabel}"
               HorizontalAlignment="Left" Margin="14,0,0,0"/>
        <Label Content="-" Name="lblFinal1" Grid.Row="4" Grid.Column="3"
               Style="{StaticResource WinnerNameLabel}"
               HorizontalAlignment="Right" Margin="0,0,56,0"/>
        <Label Content="-" Name="lblFinal1Tore" Grid.Row="4" Grid.Column="3"
               Style="{StaticResource ScoreLabel}"
               HorizontalAlignment="Right" Margin="0,0,14,0" Width="36"/>

        <Rectangle Grid.Row="12" Grid.Column="3" Style="{StaticResource BracketCard}"/>
        <Label Content="Gewinner HF 2" Grid.Row="12" Grid.Column="3"
               Style="{StaticResource HeadingLabel}"
               HorizontalAlignment="Left" Margin="14,0,0,0"/>
        <Label Content="-" Name="lblFinal2" Grid.Row="12" Grid.Column="3"
               Style="{StaticResource WinnerNameLabel}"
               HorizontalAlignment="Right" Margin="0,0,56,0"/>
        <Label Content="-" Name="lblFinal2Tore" Grid.Row="12" Grid.Column="3"
               Style="{StaticResource ScoreLabel}"
               HorizontalAlignment="Right" Margin="0,0,14,0" Width="36"/>

        <!-- ==================== Champion ==================== -->
        <Rectangle Grid.Row="8" Grid.Column="4" Style="{StaticResource BracketCard}"/>
        <Label Content="Sieger" Grid.Row="8" Grid.Column="4"
               Style="{StaticResource ChampionLabel}"
               HorizontalAlignment="Left" Margin="14,0,0,0"/>
        <Label Content="-" Name="lblSieger" Grid.Row="8" Grid.Column="4"
               Style="{StaticResource ChampionLabel}"
               HorizontalAlignment="Right" Margin="0,0,14,0"/>

        <!-- ==================== Simulation button ==================== -->
        <Button x:Name="btnSimulieren"
                Click="btnSimulieren_Click"
                Content="Simulieren"
                Grid.Row="15" Grid.Column="3" Grid.ColumnSpan="2"
                Margin="8"/>
    </Grid>
</Window>
